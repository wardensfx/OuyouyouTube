{
	http_port 8080
	https_port 8443
	# En prod, Traefik termine le TLS public puis nous parle en HTTP interne
	# (réseau du pod) : sans ça, Caddy recalcule X-Forwarded-Proto depuis SA
	# propre connexion (http) au lieu de faire confiance à celui de Traefik,
	# et le renvoie tel quel (http) au backend -> oauthlib voit un callback
	# OAuth en http et lève InsecureTransportError malgré --proxy-headers
	# côté uvicorn (qui, lui, fait bien confiance à ce que Caddy lui envoie).
	servers {
		trusted_proxies static private_ranges
	}
}

{$SITE_ADDRESS:localhost} {
	encode gzip

	@api path /api/*
	handle @api {
		reverse_proxy {$BACKEND_ADDR:backend:8000}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
