# Variables lues par docker-compose.yml (profil "prod", service frontend/Caddy).
# Copier en .env à la racine et adapter selon le contexte de déploiement.

# Caddy écoute sur 8080 (HTTP) / 8443 (HTTPS) à l'intérieur du container et
# ces ports sont publiés tels quels sur l'hôte (voir docker-compose.yml).
# Si tu passes par un vrai domaine derrière un routeur/NAT, redirige les
# ports externes 80/443 vers 8080/8443 sur cette machine.

# Local sans domaine/TLS : ":8080" (Caddy sert en HTTP simple, pas de cert).
# Prod avec domaine réel : "ouyouyoutube.mondomaine.fr" (Caddy obtient un cert
# Let's Encrypt automatiquement sur le port 8443 — le DNS doit pointer vers
# cet hôte et les ports 8080/8443 (ou 80/443 redirigés) doivent être
# joignables depuis l'extérieur pour la validation ACME).
SITE_ADDRESS=:8080
