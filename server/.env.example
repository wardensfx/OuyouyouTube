GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

SECRET_KEY=change-me-in-prod
SESSION_COOKIE_NAME=ytpwa_session

CACHE_DIR=/tmp/ytpwa_cache
VIDEO_TTL_SECONDS=1800
CLEANUP_INTERVAL_SECONDS=300

REDIS_URL=redis://localhost:6379/0
METADATA_TTL_SECONDS=900

FRONTEND_ORIGIN=http://localhost:5173

# Optionnel : export cookies.txt de ton navigateur connecté à YouTube
# (nécessaire pour limiter le throttling / accès aux vidéos restreintes)
YTDLP_COOKIES_FILE=
