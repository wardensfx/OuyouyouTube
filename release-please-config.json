{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "front/package.json",
          "jsonpath": "$.version"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "New Features 🎉" },
        { "type": "fix", "section": "Bug Fixes 🐛" },
        { "type": "docs", "section": "Documentation 📝" },
        { "type": "perf", "section": "Other Changes" },
        { "type": "refactor", "section": "Other Changes" },
        { "type": "chore", "section": "Other Changes", "hidden": true },
        { "type": "test", "section": "Other Changes", "hidden": true },
        { "type": "ci", "section": "Other Changes", "hidden": true },
        { "type": "build", "section": "Other Changes", "hidden": true }
      ]
    }
  }
}
